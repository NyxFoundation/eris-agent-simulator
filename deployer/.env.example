# anvil RPC endpoint (the Aave deploy scripts are hardcoded to localhost:8545)
RPC_URL=http://127.0.0.1:8545

# anvil default mnemonic; account index 0 is the deployer.
MNEMONIC="test test test test test test test test test test test junk"

# Set to true to have the deployer manage the anvil lifecycle (start/stop) itself.
# Set to false if anvil is already running in a separate terminal via `npm run anvil`.
MANAGE_ANVIL=true
