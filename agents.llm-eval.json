{
  "_comment": "ADR 0011 Stage2 multi-seed 検証。同一 run 内で arb-evolver(自己改善・入札を学習) と arb-frozen(同じ base arb を凍結・固定割合の過剰入札のまま) を paired 比較し、『入札学習が PnL を改善するか / 過剰修正(下げすぎ)になっていないか』を複数 seed で見る。arb-flat を低入札の場として置く。要 economicGas=1 + contested。",
  "agents": [
    {
      "id": "arb-evolver",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "arb",
        "ERIS_LLM_AUTH": "codex",
        "ERIS_LLM_REVIEW_EVERY": "15"
      },
      "description": "自己改善（入札を competition feedback で学習）"
    },
    {
      "id": "arb-frozen",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/claude-llm.ts"],
      "wallet": "AUTO",
      "env": {
        "ERIS_BASE_STRATEGY": "arb",
        "ERIS_FREEZE_STRATEGY": "1"
      },
      "description": "同じ base arb を凍結（固定割合入札・学習なし）= 対照群"
    },
    {
      "id": "arb-flat",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/arb-bot.ts"],
      "wallet": "AUTO",
      "env": { "BID_PROFIT_FRACTION": "0.0" },
      "description": "低入札の場"
    },
    {
      "id": "noop",
      "command": "node",
      "args": ["--import", "tsx", "examples/agents/noop.ts"],
      "wallet": "AUTO",
      "baseline": true
    }
  ]
}
