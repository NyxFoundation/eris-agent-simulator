{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "paths": {
      "@eris/sdk": ["./sdk/src/index.ts"],
      "@eris/sdk/*": ["./sdk/src/*"]
    }
  },
  "include": [
    "sdk/src/**/*.ts",
    "core/src/**/*.ts",
    "example/agents/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["_archive", "deployer", "node_modules", "dist"]
}
